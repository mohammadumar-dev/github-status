generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core app models
model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  githubUsername String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  cardConfigs    CardConfig[]
}

model GithubProfileCache {
  id              String   @id @default(cuid())
  username        String   @unique
  profileData     Json
  statsData       Json
  streakData      Json
  heatmapData     Json
  languagesData   Json
  reposData       Json
  activityData    Json
  commitData      Json
  lastFetchedAt   DateTime @default(now())
  expiresAt       DateTime
  fetchDurationMs Int?
  errorCount      Int      @default(0)
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
  @@index([expiresAt])
}

model CardConfig {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("My Card")
  username    String
  theme       String   @default("default")
  cards       String[] @default(["profile", "stats", "streak", "heatmap", "langs", "repos"])
  accentColor String?
  bgColor     String?
  textColor   String?
  titleColor  String?
  borderColor String?
  iconColor   String?
  hideBorder  Boolean  @default(false)
  hideRank    Boolean  @default(false)
  showIcons   Boolean  @default(true)
  locale      String   @default("en")
  cacheSeconds Int     @default(3600)
  isPublic    Boolean  @default(false)
  shareSlug   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([shareSlug])
}

model RateLimitLog {
  id        String   @id @default(cuid())
  username  String
  ip        String?
  endpoint  String
  createdAt DateTime @default(now())

  @@index([username, createdAt])
  @@index([ip, createdAt])
}
